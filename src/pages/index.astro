  function getLang() {
    var raw = navigator.language || navigator.userLanguage || 'en';
    var code = raw.toLowerCase().split('-')[0];
    // Filipino / Tagalog mappings
    if (code === 'tl' || code === 'fil') return 'fil';
    if (code === 'es') return 'es';
    if (code === 'fr') return 'fr';
    return 'en';
  }

  function applyTranslations(lang) {
    var t = translations[lang] || translations['en'];
    var els = document.querySelectorAll('[data-i18n]');
    for (var i = 0; i < els.length; i++) {
      var el = els[i];
      var key = el.getAttribute('data-i18n');
      if (t[key] !== undefined) {
        // preserve inner HTML links in footer
        if (key === 'footerLinked') {
          el.innerHTML = t[key].replace('rosari.org', '<a href="https://rosari.org" rel="noopener">rosari.org</a>');
        } else if (key === 'scrollBody') {
          // preserve <em> and <strong> inside scroll body
          el.textContent = t[key];
        } else {
          el.textContent = t[key];
        }
      }
    }
    // Set html lang attribute
    var langMap = { fil: 'tl', es: 'es', fr: 'fr', en: 'en' };
    document.documentElement.lang = langMap[lang] || 'en';
  }

  var lang = getLang();
  if (lang !== 'en') {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { applyTranslations(lang); });
    } else {
      applyTranslations(lang);
    }
  }
})();
