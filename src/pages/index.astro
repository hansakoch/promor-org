---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Promor — Promotor Fidei"
  description="Guardian of Sacred Tradition. A tool that examines doctrine, defends the Latin Mass, and upholds the perennial Faith. Launching after Easter."
>

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar" aria-label="Site navigation">
    <div class="container">
      <span class="navbar-brand">Promor.org</span>
      <span class="navbar-tagline" data-i18n="navTagline">Pro Sancta Traditione</span>
      <span class="navbar-cross" aria-hidden="true">✠</span>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <header class="hero" id="top">
    <div class="hero-inner">
      <span class="hero-eyebrow">Officium Promotor Fidei · Est. MMXXV</span>

      <h1 class="hero-title">
        Promotor Fidei
        <span class="hero-title-latin" data-i18n="heroTitleSub">Promoter of the Faith · Guardian of Tradition</span>
      </h1>

      <p class="hero-subtitle" data-i18n="heroSubtitle">
        Guardian of Sacred Tradition. Coming soon: a tool that examines
        doctrine, defends the Latin Mass, and upholds the perennial Faith.
      </p>

      <a href="#mission" class="hero-cta" data-i18n="heroCta">Learn More — Disce Plus</a>

      <p class="hero-scroll-hint" aria-hidden="true">↓ &nbsp; Descende &nbsp; ↓</p>
    </div>
  </header>

  <!-- ===== GALLERY ===== -->
  <section class="gallery" aria-label="Historical imagery">
    <div class="container">
      <div class="gallery-grid">

        <!-- Image 1: Historical Vatican debate — Gutenberg public domain JPG -->
        <div class="gallery-item">
          <img
            src="https://www.gutenberg.org/cache/epub/73559/images/i_f004.jpg"
            alt="Historical Vatican courtroom — robed theologians in solemn doctrinal debate"
            loading="lazy"
            decoding="async"
            width="600"
            height="375"
          />
          <span class="gallery-caption">Congregatio pro Causis Sanctorum · c. XVII</span>
        </div>

        <!-- Image 2: Raphael Disputa — local SVG, always loads, zero bandwidth cost -->
        <div class="gallery-item">
          <img
            src="/images/raphael-disputa.svg"
            alt="Disputation of the Holy Sacrament — theologians and saints assembled before the Blessed Sacrament, after Raphael"
            loading="lazy"
            decoding="async"
            width="800"
            height="500"
            fetchpriority="low"
          />
          <span class="gallery-caption">Disputatio de Eucharistia · Post Raphael, c. MDX</span>
        </div>

        <!-- Image 3: Latin Vulgate parchment — local SVG, always loads -->
        <div class="gallery-item">
          <img
            src="/images/latin-scripture.svg"
            alt="Biblia Sacra Vulgata — Latin sacred scripture, In principio erat Verbum, Saint John Chapter I"
            loading="lazy"
            decoding="async"
            width="800"
            height="500"
            fetchpriority="low"
          />
          <span class="gallery-caption">Biblia Sacra Vulgata · Ioannes I · c. MCDLV</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== MISSION / ABOUT ===== -->
  <section class="about" id="mission">
    <div class="container">
      <div class="about-grid">

        <div>
          <p class="section-label" data-i18n="missionLabel">Quid Est Hoc?</p>
          <h2 class="section-title" data-i18n="missionTitle">An Advocate<br />for the Old Ways</h2>
          <div class="section-body">
            <p data-i18n="missionP1">
              In the Roman Rite's canonization process, the <em>Promotor Fidei</em>—
              known as the "Devil's Advocate"—was appointed to argue against sainthood,
              demanding rigorous proof of holiness. We revive that sacred office for doctrine.
            </p>
            <p data-i18n="missionP2">
              A tool for traditional Catholics. Examines liturgical and
              doctrinal documents, identifies deviations from Tradition, and
              upholds the old rite — quietly and faithfully.
            </p>
          </div>

          <span class="launch-badge">
            <span class="dot" aria-hidden="true"></span>
            <span data-i18n="launchBadge">Launching after Easter · Ora pro nobis</span>
          </span>
        </div>

        <div>
          <p class="section-label" data-i18n="featuresLabel">Functiones</p>
          <h2 class="section-title" data-i18n="featuresTitle">What It Does</h2>
          <ul class="feature-list" role="list">
            <li data-i18n="feat1">Examines liturgical documents for doctrinal deviations</li>
            <li data-i18n="feat2">Cross-references Trent, Vatican I, and pre-1962 rubrics</li>
            <li data-i18n="feat3">Identifies ambiguities and issues formal canonical objections</li>
            <li data-i18n="feat4">Generates canonical citations in Latin and English</li>
            <li data-i18n="feat5">Runs locally — nothing is sent anywhere, ever</li>
            <li data-i18n="feat6">Designed for parish and sacristy use</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== DEMO SCROLL ===== -->
  <section class="ai-demo-section" id="demo" aria-label="Formal examination demonstration">
    <div class="container">
      <div class="text-center mt-1" style="margin-bottom: 2.5rem;">
        <p class="section-label" style="display:inline-block;">Exemplum Formale</p>
        <h2 class="section-title" style="color: var(--text-primary);" data-i18n="demoTitle">A Formal Examination</h2>
      </div>

      <div id="ai-demo" role="article" aria-label="Sample formal examination output">
        <div class="scroll-wax-seal" aria-hidden="true">✠</div>

        <p class="scroll-heading">Promotor Fidei · Examen Formale · Anno Domini 2025</p>

        <div class="scroll-ruling" aria-hidden="true">Obiectio Formalis</div>

        <p class="scroll-title" data-i18n="scrollTitle">Document Analysis: Post-Synodal Exhortation, §8 ¶4</p>

        <p class="scroll-verdict">
          <strong data-i18n="scrollVerdict">"This change to Mass deviates from sacred Tradition — here is why:"</strong><br /><br />

          <span data-i18n="scrollBody">The proposed alteration to the Offertory prayer omits the oblation formula
          <em>"offerimus praeclarae maiestati tuae"</em> in favour of a vernacular paraphrase
          that severs the sacrificial character of the rite. Canon 817 of the 1917 Code
          and <em>Mediator Dei</em> §§ 48–50 are dispositive: the Mass is not a meal-memorial
          but the unbloody re-presentation of Calvary. Any text that obscures this is
          <strong>materially defective</strong> and may not licitly be substituted.
          Tridentine Session XXII, Canon III anathematizes precisely this reduction.</span>

          <cite class="scroll-cite">— Promotor Fidei · Obiectio Formalis · Citations: 7</cite>
        </p>

        <hr class="scroll-footer-rule" />

        <p class="scroll-status">
          <span class="scroll-status-dot" aria-hidden="true"></span>
          <span data-i18n="scrollStatus">Sample output · Full engine launching post-Easter</span>
        </p>
      </div>

    </div>
  </section>

  <!-- ===== TEASER ===== -->
  <section class="teaser" id="teaser">
    <div class="container">
      <div class="teaser-card">
        <p class="section-label" style="display:inline-block; margin-bottom: 1.5rem;" data-i18n="teaserLabel">Pro Fidelibus Traditionalibus</p>
        <p class="teaser-text" data-i18n="teaserText">
          An offline tool for traditional Catholics.
          <strong>Examines documents, identifies deviations from Tradition,</strong>
          upholds the old rite — quietly and faithfully.
          Launching after Easter.
        </p>
        <p class="rosary-note">✠ &nbsp; <span data-i18n="rosaryNote">Pray the Holy Rosary while we prepare</span> &nbsp; ✠</p>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <div class="footer-inner">

        <div class="footer-brand">
          Promor.org
          <span>Promotor Fidei · Officium Fidei</span>
        </div>

        <div class="footer-links">
          <span data-i18n="footerLinked">Linked to <a href="https://rosari.org" rel="noopener">rosari.org</a></span>
        </div>

        <div class="footer-status">
          <span data-i18n="footerLaunch">Launching post-Easter · Ora pro nobis</span>
        </div>

      </div>

      <div class="footer-bottom">
        <span>✠ &nbsp; Ad maiorem Dei gloriam &nbsp; ✠ &nbsp; &copy; {new Date().getFullYear()} Promor.org &nbsp; ✠</span>
      </div>
    </div>
  </footer>

</Layout>

