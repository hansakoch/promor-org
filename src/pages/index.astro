---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Promor — Promotor Fidei AI"
  description="Digital guardian of tradition. AI that critiques heresy, defends the Latin Mass, and promotes the old rite. Coming soon — zero tracking, built for trad Catholics."
>

  <!-- ===== NAVBAR ===== -->
  <nav class="navbar" aria-label="Site navigation">
    <div class="container">
      <span class="navbar-brand">Promor.org</span>
      <span class="navbar-tagline">Advocatus Diaboli · Pro Traditione</span>
      <span class="navbar-cross" aria-hidden="true">✠</span>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <header class="hero" id="top">
    <div class="hero-inner">
      <span class="hero-eyebrow">Officium Promotor Fidei · Est. MMXXV</span>

      <h1 class="hero-title">
        Promotor Fidei
        <span class="hero-title-latin">Promoter of the Faith · Devil's Advocate</span>
      </h1>

      <p class="hero-subtitle">
        Digital guardian of tradition. Coming soon: AI that critiques heresy,
        defends the Latin Mass, no fluff.
      </p>

      <a href="#about" class="hero-cta">Disce Plus — Learn More</a>

      <p class="hero-scroll-hint" aria-hidden="true">↓ &nbsp; Descende &nbsp; ↓</p>
    </div>
  </header>

  <!-- ===== GALLERY ===== -->
  <section class="gallery" aria-label="Historical imagery">
    <div class="container">
      <div class="gallery-grid">

        <!-- Image 1: Vatican courtroom debate painting -->
        <div class="gallery-item">
          <img
            src="https://www.gutenberg.org/cache/epub/73559/images/i_f004.jpg"
            alt="Historical Vatican courtroom — robed theologians debate by quill and candlelight"
            loading="lazy"
            width="600"
            height="400"
          />
          <span class="gallery-caption">Congregatio pro Causis Sanctorum · c. XVII</span>
        </div>

        <!-- Image 2: Medieval parchment with calligraphy -->
        <div class="gallery-item">
          <img
            src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgMb1AbWa7RszNay3c81LLc499xHsohTdSdpY7rbXSSTQVVr5IfBMtW1anyTf3KzENqa9O_ItfrxlS7dwByNXb6rFXk-6t3qENpGL0TSncNfOtMp9yuT0fy9KL0C7jOJ7HPsuKi72xmdyFL78IuYfcZ3OTSK7tdNvBruzhJZ9IwRpYYG0MuEq6TBWkgxhVg/s1500/CANTARINI-%20May%206%20revised_html_m42eb8a7f.jpg"
            alt="Medieval illuminated manuscript — Promotor Fidei calligraphy on aged parchment"
            loading="lazy"
            width="600"
            height="400"
          />
          <span class="gallery-caption">Promotor Fidei · Manuscriptum Sacrum</span>
        </div>

        <!-- Image 3: Public domain Vatican image placeholder -->
        <div class="gallery-item">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8a/Sanzio_01.jpg/800px-Sanzio_01.jpg"
            alt="Raphael's School of Athens — philosophers and theologians in solemn debate"
            loading="lazy"
            width="600"
            height="400"
          />
          <span class="gallery-caption">In Disputatione Veritatis · Raphael, 1511</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== ABOUT / FEATURES ===== -->
  <section class="about" id="about">
    <div class="container">
      <div class="about-grid">

        <div>
          <p class="section-label">Quid Est Hoc?</p>
          <h2 class="section-title">An Advocate<br />for the Old Ways</h2>
          <div class="section-body">
            <p>
              In the Roman Rite's canonization process, the <em>Promotor Fidei</em>—
              popularly the "Devil's Advocate"—was appointed to argue against sainthood,
              forcing rigorous proof. We revive that office for doctrine.
            </p>
            <p>
              Offline tool for trad Catholics. Scans documents, roasts Novus Ordo
              slips, promotes the old rite. Built for Father Chazal's crew—zero
              tracking, USB drops only.
            </p>
          </div>

          <span class="launch-badge">
            <span class="dot" aria-hidden="true"></span>
            Launching after Easter · Ora pro nobis
          </span>
        </div>

        <div>
          <p class="section-label">Functiones</p>
          <h2 class="section-title">What It Does</h2>
          <ul class="feature-list" role="list">
            <li>Scans liturgical documents for doctrinal deviations</li>
            <li>Cross-references Trent, Vatican I, and pre-1962 rubrics</li>
            <li>Identifies Novus Ordo ambiguities and issues formal objections</li>
            <li>Generates canonical citations in Latin and English</li>
            <li>Runs fully offline — no cloud, no tracking, no concessions</li>
            <li>USB-deployable for sacristy use after High Mass</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== AI DEMO SCROLL ===== -->
  <section class="ai-demo-section" id="demo" aria-label="AI critique demonstration">
    <div class="container">
      <div class="text-center mt-1" style="margin-bottom: 2rem;">
        <p class="section-label" style="display:inline-block;">Exemplum Artificiale</p>
        <h2 class="section-title" style="color: var(--text-primary);">The AI in Action</h2>
      </div>

      <!-- THE SCROLL — required element per spec -->
      <div id="ai-demo" role="article" aria-label="Sample AI critique output">
        <div class="scroll-wax-seal" aria-hidden="true">✠</div>

        <p class="scroll-heading">Promotor Fidei · Criticus Artificialis · Anno Domini 2025</p>

        <div class="scroll-ruling" aria-hidden="true">Obiectio Formalis</div>

        <p class="scroll-title">Documenti Analysis: Post-Synodal Exhortation, §8 ¶4</p>

        <p class="scroll-verdict">
          <strong>"This change to Mass? Bullshit — here's why:"</strong><br /><br />

          The proposed alteration to the Offertory prayer omits the oblation formula
          <em>"offerimus praeclarae maiestati tuae"</em> in favor of a vernacular paraphrase
          that severs the sacrificial character of the rite. Canon 817 of the 1917 Code
          and <em>Mediator Dei</em> §§ 48–50 are dispositive: the Mass is not a meal-memorial
          but the unbloody re-presentation of Calvary. Any text that obscures this is
          <strong>materially defective</strong> and may not licitly be substituted.
          Tridentine Session XXII, Canon III anathematizes precisely this reduction.

          <cite class="scroll-cite">— Promotor Fidei Engine v0.1 · Confidence: 94.7% · Citations: 7</cite>
        </p>

        <hr class="scroll-footer-rule" />

        <p class="scroll-status">
          <span class="scroll-status-dot" aria-hidden="true"></span>
          AI Critique Placeholder · Full engine launching post-Easter
        </p>
      </div>

    </div>
  </section>

  <!-- ===== TEASER ===== -->
  <section class="teaser" id="teaser">
    <div class="container">
      <div class="teaser-card">
        <p class="section-label" style="display:inline-block; margin-bottom: 1.25rem;">Pro Patribus Traditionalibus</p>
        <p class="teaser-text">
          Offline tool for trad Catholics. Scans docs, roasts Novus Ordo slips,
          promotes old rite. <strong>Built for Father Chazal's crew</strong>—zero
          tracking, USB drops only. Launching after Easter.
        </p>
        <p class="rosary-note">✠ &nbsp; Pray the Rosary while we code &nbsp; ✠</p>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <div class="footer-inner">

        <div class="footer-brand">
          Promor.org
          <span>Promotor Fidei · Digital Office</span>
        </div>

        <div class="footer-links">
          <span>Linked to <a href="https://rosari.org" rel="noopener">rosari.org</a></span>
          <span>Contact: <a href="mailto:contact@promor.org">contact@promor.org</a></span>
          <span style="color: var(--text-dim);">Zero tracking · No cookies · USB-first</span>
        </div>

        <div class="footer-status">
          <strong>Under construction</strong><br />
          <span>Launching post-Easter · Ora pro nobis</span>
        </div>

      </div>

      <div class="footer-bottom">
        <span>✠ &nbsp; Ad maiorem Dei gloriam &nbsp; ✠ &nbsp; &copy; {new Date().getFullYear()} Promor.org &nbsp; ✠</span>
      </div>
    </div>
  </footer>

</Layout>
